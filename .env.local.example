# Public site URL (used for QR code generation)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — leave empty to run in DEMO MODE (in-memory store, no persistence)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (optional). If empty, moderation falls back to a Hebrew heuristic filter.
OPENAI_API_KEY=

# Optional admin gate. Leave empty for open admin in demo mode.
ADMIN_PASSWORD=
